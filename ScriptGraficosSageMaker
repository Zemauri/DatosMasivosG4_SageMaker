import pandas as pd                             #Importar librería pandas (pd) para el manejo de datos en estructuras.
import matplotlib.pyplot as plt                 #Importar librería que son los gráficos básicos en Python.
import seaborn as sns                           #Importar librería para gráficos estadísticos más estilizados.
import awswrangler as wr                        #Importar librería para interactuar con datos en AWS Glue en este caso.
from matplotlib.ticker import FuncFormatter     #Importar librería para personalizar el formato en gráficos.

# Ruta en S3
path = "s3://datosmasivos-g4-dataset/processed/"                                    #Definir la ubicación en S3 donde están los datos en formato Parquet.
cols = ["product_category", "total_sales", "age", "transaction_date", "churned"]    #Lista de columnas que se van a leer del dataset.

# Leer datos
df = wr.s3.read_parquet(path=path, columns=cols)                                    #Se carga el archivo Parquet desde S3 en un DataFrame de pandas, pero solo con las columnas especificadas.

# -------------------------------
# 1. ANÁLISIS DE CATEGORÍAS
# -------------------------------
analisis_ventas = (
    df.groupby('product_category')['total_sales']       #Agrupa las ventas por categoría de producto.
    .agg(['sum','mean'])                                #Calcula suma total y promedio de ventas por categoría.
    .sort_values(by='sum', ascending=False)             #Ordena las categorías de mayor a menor.
)

top_categoria = analisis_ventas.index[0]                #Identifica la categoría con mayores ventas.
max_ventas = analisis_ventas['sum'].iloc[0]             #Obtiene el valor máximo de ventas.
promedio_top = analisis_ventas['mean'].iloc[0]          #Calcula el ticket promedio de esa categoría.

colores = ["red" if cat==top_categoria else "gray" for cat in analisis_ventas.index]    #Colorea la barra de la categoría top en rojo, las demás en gris.

plt.figure(figsize=(10,6))
sns.barplot(x=analisis_ventas.index, y=analisis_ventas['sum'], hue=analisis_ventas.index,
            palette=colores, legend=False)                                                                                                          #Genera un gráfico de barras mostrando las ventas totales por categoría.
plt.title(f"Categoría con mayores ingresos: {top_categoria}\nTotal: ${max_ventas:,.2f} | Ticket promedio: ${promedio_top:,.2f}")                    #Resalta la categoría líder en rojo.
plt.ylabel("Ventas Totales")
plt.xticks(rotation=45)
plt.gca().yaxis.set_major_formatter(FuncFormatter(lambda x, _: f"${x:,.0f}"))                                                                       #Formatea el eje Y para mostrar valores en formato monetario.
plt.show()

# -------------------------------
# 2. ANÁLISIS DEMOGRÁFICO
# -------------------------------
edad_promedio = df['age'].mean()
edad_mediana = df['age'].median()
edad_min = df['age'].min()                  #Calcula estadísticas descriptivas de la edad: promedio, mediana, mínimo y máximo.
edad_max = df['age'].max()

plt.figure(figsize=(8,6))
sns.boxplot(x=df['age'], color="skyblue")
plt.axvline(edad_promedio, color="red", linestyle="--", label=f"Promedio: {edad_promedio:.2f}")
plt.axvline(edad_mediana, color="green", linestyle="--", label=f"Mediana: {edad_mediana:.2f}")                                              #Dibuja un boxplot de la distribución de edades.
plt.title(f"Distribución de Edad\nPromedio: {edad_promedio:.2f} | Mediana: {edad_mediana:.2f} | Rango: {edad_min}-{edad_max}")              #Añade líneas verticales para marcar el promedio y la mediana.
plt.xlabel("Edad")
plt.legend()
plt.show()                                                                                                                                  #Muestra el rango completo de edades en el título.

# -------------------------------
# 3. ANÁLISIS DE TENDENCIAS
# -------------------------------
df['transaction_date'] = pd.to_datetime(df['transaction_date'])                                         #Convierte la columna transaction_date a formato de fecha.
ventas_diarias = df.groupby(df['transaction_date'].dt.date)['total_sales'].sum()                        #Agrupa las ventas por día y calcula la suma diaria.



promedio_diario = ventas_diarias.mean()                                                     #Calcula el promedio de ventas diarias.
max_dia = ventas_diarias.idxmax()
max_valor = ventas_diarias.max()                                                            #Identifica el día con mayor ventas (max_dia) y su valor (max_valor).
min_dia = ventas_diarias.idxmin()
min_valor = ventas_diarias.min()                                                            #Identifica el día con menor ventas (min_dia) y su valor (min_valor).




plt.figure(figsize=(12,6))                                                                                              #Crea una nueva figura de Matplotlib con tamaño 12 pulgadas de ancho y 6 pulgadas de alto.
ventas_diarias.plot(label="Ventas Diarias", color="lightblue")                                                          #Grafica la serie ventas_diarias (ventas totales por día). Añade una etiqueta.
plt.axhline(promedio_diario, color="orange", linestyle="--", label=f"Promedio: ${promedio_diario:,.0f}")                #Dibuja una línea horizontal en el valor del promedio diario (promedio_diario).
plt.scatter(max_dia, max_valor, color="green", s=100, label=f"Máximo {max_dia}: ${max_valor:,.0f}")                     #Coloca un punto verde en el día con mayor ventas (max_dia, max_valor).
plt.scatter(min_dia, min_valor, color="red", s=100, label=f"Mínimo {min_dia}: ${min_valor:,.0f}")                       #Coloca un punto rojo en el día con menor ventas (min_dia, min_valor).
plt.title(f"Tendencia de Ventas Diarias\nDiferencia Máx-Mín: ${max_valor - min_valor:,.2f}")                            #Define el título del gráfico.
plt.ylabel("Ventas Totales")                                                                                            #Etiqueta del eje Y
plt.xlabel("Fecha")                                                                                                     #Etiqueta del eje X
plt.xticks(rotation=45)                                                                                                 #Rota las etiquetas del eje X 45 grados para que las fechas se lean mejor.
plt.legend()                                                                                                            #Muestra la leyenda con las etiquetas definidas en plot, axhline y scatter.
plt.gca().yaxis.set_major_formatter(FuncFormatter(lambda x, _: f"${x:,.0f}"))                                           #Obtiene el eje Y y cambia formato para mostrar el dinero.
plt.show()                                                                                                              #Renderiza y muestra el gráfico en pantalla.






